{
  "expo": {
    "name": "عقارات المستقبل",
    "slug": "real-estate",
    "version": "1.0.17",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "realestate",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A5C2E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mustaqbal.realestate",
      "buildNumber": "24",
      "infoPlist": {
        "CFBundleDisplayName": "شقق وأراضي\nالمستقبل",
        "NSCameraUsageDescription": "يستخدم التطبيق الكاميرا لالتقاط صور العقارات وإضافتها للإعلانات فقط، ولا تُستخدم لأي غرض آخر.",
        "NSPhotoLibraryUsageDescription": "يستخدم التطبيق معرض الصور لاختيار صور العقارات وإضافتها للإعلانات فقط، ولا تُستخدم لأي غرض آخر.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["85F4.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false
      }
    },
    "android": {
      "package": "com.mustaqbal.realestate",
      "versionCode": 14,
      "targetSdkVersion": 34,
      "compileSdkVersion": 34,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1A5C2E"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "يستخدم التطبيق معرض الصور لاختيار صور العقارات وإضافتها للإعلانات فقط.",
          "cameraPermission": "يستخدم التطبيق الكاميرا لالتقاط صور العقارات وإضافتها للإعلانات فقط."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "affdc62f-ef83-4c2b-a9cb-eb4c92b8df6f"
      }
    },
    "owner": "josefbo1987"
  }
}
